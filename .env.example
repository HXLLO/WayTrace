# Scraping
MAX_CONCURRENT_SCRAPES=30
ARCHIVE_REQUEST_TIMEOUT=30
ARCHIVE_RETRY_COUNT=3
SCRAPE_DELAY_MIN=0.02
SCRAPE_DELAY_MAX=0.08
SCRAPE_MAX_RETRIES=3

# Jobs
JOB_TTL_SECONDS=7200
MAX_ACTIVE_JOBS=10
SCAN_TIMEOUT_SECONDS=3600

# Caches
PAGE_CACHE_MAX_MB=512
CDX_CACHE_TTL=300
PAGE_CACHE_TTL=300

# Preflight
PRESCRAPE_LIMIT=15
COLLAPSE_THRESHOLD=250000

# Rate limiting (0 = disabled)
SCAN_RATE_LIMIT_RPM=10

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=INFO
